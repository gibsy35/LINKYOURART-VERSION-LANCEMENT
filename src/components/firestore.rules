rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Phase 3: Primitives & Global Helpers
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true || isAdmin()); }
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower() in ["linkyourart@gmail.com", "lequimejeanbaptiste@gmail.com", "linkart@gmail.com"];
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Entity Validations
    // ===============================================================
    
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string;
    }

    function isValidProject(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.issuerUid == request.auth.uid &&
             data.status in ['PENDING', 'APPROVED', 'REJECTED'];
    }

    function isValidMessage(data) {
      return data.fromId == request.auth.uid &&
             data.toId is string && isValidId(data.toId) &&
             data.subject is string && data.subject.size() <= 200 &&
             data.body is string && data.body.size() <= 5000;
    }

    // ===============================================================
    // match Blocks
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isSignedIn(); // Allow all signed in users to read projects for Discovery
      allow create: if isVerified() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isVerified() && (existing().issuerUid == request.auth.uid || isAdmin()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'image', 'milestones'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow get: if isSignedIn() && (existing().fromId == request.auth.uid || existing().toId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isVerified() && isValidId(messageId) && isValidMessage(incoming());
      allow update: if isOwner(incoming().fromId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read, write: if false; // System only
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
