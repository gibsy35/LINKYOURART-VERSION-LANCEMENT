rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Primitives & Global Helpers
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true || isAdmin()); }
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email != null && 
             (
               request.auth.token.email.lower() == "linkyourart@gmail.com" || 
               request.auth.token.email.lower() == "lequimejeanbaptiste@gmail.com" || 
               request.auth.token.email.lower() == "jeanbaptistelequime@gmail.com" ||
               request.auth.token.email.lower() == "lyacontactpro@gmail.com" ||
               request.auth.token.email.lower() == "linkart@gmail.com" ||
               request.auth.token.email.lower() == "admin@linkyourart.com" ||
               request.auth.token.email.lower() == "superadmin@linkyourart.com"
             );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Entity Validations
    // ===============================================================
    
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200;
    }

    function isValidProject(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.issuerUid == request.auth.uid &&
             data.status in ['PENDING', 'APPROVED', 'REJECTED'];
    }

    function isValidMessage(data) {
      return data.fromId == request.auth.uid &&
             data.toId is string && isValidId(data.toId) &&
             data.subject is string && data.subject.size() <= 200 &&
             data.body is string && data.body.size() <= 5000;
    }

    function isValidLoungePost(data) {
      return data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.content is string && data.content.size() <= 2000;
    }

    // ===============================================================
    // match Blocks
    // ===============================================================

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId}/contracts/{contractId} {
      allow list, get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      // Secure List Queries (Pillar 8): Enforce that users list their own projects or be an admin
      allow list: if isSignedIn() && (resource.data.issuerUid == request.auth.uid || isAdmin());
      allow get: if isSignedIn();
      allow create: if isVerified() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isVerified() && (existing().issuerUid == request.auth.uid || isAdmin()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'image', 'milestones'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow get: if isSignedIn() && (existing().fromId == request.auth.uid || existing().toId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidId(messageId) && isValidMessage(incoming());
      allow update: if (isOwner(existing().fromId) || isOwner(existing().toId)) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    match /lounge_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(postId) && isValidLoungePost(incoming());
      allow update: if isVerified() && (existing().authorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read, write: if false; // System only
    }

    match /test/connection {
      allow read: if true;
    }

    // Default Deny (Safety Net)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
